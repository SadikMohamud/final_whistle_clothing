DJANGO_SECRET_KEY=replace-with-secure-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=postgres://user:password@localhost:5432/finalwhistle
SITE_URL=https://finalwhistleclothing.com

GOOGLE_OAUTH2_KEY=your-google-oauth-client-id
GOOGLE_OAUTH2_SECRET=your-google-oauth-client-secret

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-email-provider-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@finalwhistleclothing.com

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token
SHOPIFY_STOREFRONT_API_VERSION=2025-01
SHOPIFY_ADMIN_ACCESS_TOKEN=your-shopify-admin-api-token
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
